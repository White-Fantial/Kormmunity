generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  COORDINATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  LIMITED
  SUSPENDED
  DELETED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HELD
  DELETED
}

enum CommentStatus {
  PUBLISHED
  HELD
  DELETED
}

enum CategoryType {
  GENERAL
  QUESTION
  SALE
  GIVEAWAY
  RECRUIT
  HOUSING
  SERVICE
  EVENT
  COLUMN
  ADVERTISEMENT
  NOTICE
}

enum CategoryVisibilityMode {
  NORMAL
  ALWAYS_INCLUDED
  HIDDEN
}

enum PermissionSubjectType {
  USER
  ROLE
}

enum KakaoMessageDeliveryType {
  SEARCH_ALERT
  COMMENT_NOTIFICATION
}

enum NotificationType {
  POST_LIKE
  COMMENT_CREATED
  COMMENT_LIKE
  BEST_COMMENT_SELECTED
  POST_HELD
  COMMENT_HELD
}

enum KakaoMessageDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ReportReviewStatus {
  PENDING
  VALID
  FALSE_REPORT
}

enum DisplayAuthorType {
  USER
  OPERATOR_PROFILE
}

model User {
  id                   String             @id @default(cuid())
  kakaoId              String             @unique
  displayName          String
  profileImageUrl      String?
  neighbourWarmth      Float              @default(36.5)
  kakaoAccessToken     String?
  kakaoRefreshToken    String?
  kakaoAccessTokenExpiresAt DateTime?
  openChatUrl          String?
  cityId               String?
  countryId            String?
  role                 UserRole           @default(USER)
  status               UserStatus         @default(ACTIVE)
  city                 City?              @relation(fields: [cityId], references: [id])
  country              Country?           @relation(fields: [countryId], references: [id])
  posts                Post[]
  comments             Comment[]
  sessions             Session[]
  moderationLogs       ModerationAction[] @relation("ModerationActor")
  restrictions         UserRestriction[]  @relation("RestrictedUser")
  createdRestrictions  UserRestriction[]  @relation("RestrictionCreatedBy")
  reviewedRestrictions UserRestriction[]  @relation("RestrictionReviewedBy")
  notifyOnKakaoForSearchAlert Boolean            @default(true)
  notifyOnKakaoForComment     Boolean            @default(true)
  searchAlerts         SearchAlert[]
  postReports          PostReport[]
  commentReports       CommentReport[]
  savedPosts           SavedPost[]
  postLikes            PostLike[]
  commentLikes         CommentLike[]
  postPermissions      PostPermission[]
  kakaoMessageDeliveries KakaoMessageDelivery[]
  notifications        Notification[]
  reviewedPostReports  PostReport[]         @relation("PostReportReviewer")
  reviewedCommentReports CommentReport[]    @relation("CommentReportReviewer")
  warmthLogs           NeighbourWarmthLog[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Country {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  users     User[]
  cities    City[]
  posts     Post[]
  permissions PostPermission[]
}

model City {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  countryId String?
  country   Country? @relation(fields: [countryId], references: [id])
  users     User[]
  posts     Post[]
  permissions PostPermission[]
}

model Category {
  id             String                 @id @default(cuid())
  name           String
  slug           String                 @unique
  type           CategoryType           @default(GENERAL)
  visibilityMode CategoryVisibilityMode @default(NORMAL)
  color          String?
  requireCommentBeforeContactDefault Boolean @default(false)
  contactSectionDefaultExpanded      Boolean @default(false)
  quickCommentTemplates Json?
  isActive       Boolean                @default(true)
  sortOrder      Int                    @default(0)
  posts          Post[]
  permissions    PostPermission[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model PostTagOption {
  id           String       @id @default(cuid())
  categoryType CategoryType
  label        String
  slug         String
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  posts        PostTag[]

  @@unique([categoryType, label])
  @@unique([categoryType, slug])
  @@index([categoryType, isActive, sortOrder])
}

model PostPermission {
  id          String                @id @default(cuid())
  subjectType PermissionSubjectType
  userId      String?
  role        UserRole?
  countryId   String?
  cityId      String?
  categoryId  String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  user        User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  country     Country?              @relation(fields: [countryId], references: [id], onDelete: Cascade)
  city        City?                 @relation(fields: [cityId], references: [id], onDelete: Cascade)
  category    Category?             @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([subjectType, userId])
  @@index([subjectType, role])
  @@index([countryId, cityId, categoryId])
}

model Post {
  id              String       @id @default(cuid())
  authorId        String
  cityId          String?
  countryId       String?
  categoryId      String
  title           String?
  body            String
  price           Decimal?     @db.Decimal(10, 2)
  status          PostStatus   @default(PUBLISHED)
  communityScore  Float        @default(0)
  requireCommentBeforeContact Boolean @default(false)
  isPinned        Boolean      @default(false)
  pinnedAt        DateTime?
  heldReason      String?
  deletedReason   String?
  author          User         @relation(fields: [authorId], references: [id])
  city            City?        @relation(fields: [cityId], references: [id])
  country         Country?     @relation(fields: [countryId], references: [id])
  category        Category     @relation(fields: [categoryId], references: [id])
  contactUrl      String?
  images          PostImage[]
  tags            PostTag[]
  comments        Comment[]    @relation("PostComments")
  postLikes       PostLike[]
  bestCommentId   String?
  bestComment     Comment?     @relation("PostBestComment", fields: [bestCommentId], references: [id], onDelete: SetNull)
  reports         PostReport[]
  savedBy         SavedPost[]
  scoreEvents     CommunityScoreEvent[]
  displayAuthorType DisplayAuthorType @default(USER)
  displayAuthorId   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  publishedAt     DateTime?    @default(now())
  heldAt          DateTime?
  deletedAt       DateTime?

  @@index([cityId, categoryId, status, createdAt])
  @@index([authorId, createdAt])
  @@index([status, createdAt])
  @@index([status, isPinned(sort: Desc), pinnedAt(sort: Desc), createdAt(sort: Desc), id])
  @@index([status, countryId, createdAt, id])
  @@index([status, cityId, createdAt, id])
  @@index([status, categoryId, createdAt, id])
  @@index([authorId, status, createdAt])
  @@index([bestCommentId])
}

model PostTag {
  postId          String
  postTagOptionId String
  createdAt       DateTime      @default(now())
  post            Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  postTagOption   PostTagOption @relation(fields: [postTagOptionId], references: [id], onDelete: Cascade)

  @@id([postId, postTagOptionId])
  @@index([postTagOptionId, createdAt])
  @@index([postId, createdAt])
  @@index([postTagOptionId, postId])
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@index([userId, createdAt, id])
  @@index([postId, createdAt])
}

model ReportOption {
  id             String          @id @default(cuid())
  label          String          @unique
  isActive       Boolean         @default(true)
  sortOrder      Int             @default(0)
  reports        PostReport[]
  commentReports CommentReport[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PostReport {
  id               String       @id @default(cuid())
  postId           String
  reporterId       String
  optionId         String
  additionalReason String?
  reviewStatus     ReportReviewStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewedById     String?
  post             Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter         User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy       User?        @relation("PostReportReviewer", fields: [reviewedById], references: [id])
  option           ReportOption @relation(fields: [optionId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([postId, reporterId])
  @@index([postId, createdAt])
  @@index([reporterId, createdAt])
  @@index([reviewStatus, createdAt])
}

model CommentReport {
  id               String       @id @default(cuid())
  commentId        String
  reporterId       String
  optionId         String
  additionalReason String?
  reviewStatus     ReportReviewStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewedById     String?
  comment          Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter         User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy       User?        @relation("CommentReportReviewer", fields: [reviewedById], references: [id])
  option           ReportOption @relation(fields: [optionId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([commentId, reporterId])
  @@index([commentId, createdAt])
  @@index([reporterId, createdAt])
  @@index([reviewStatus, createdAt])
}

model PostImage {
  id               String   @id @default(cuid())
  postId           String
  url              String
  provider         String
  providerPublicId String?
  width            Int?
  height           Int?
  sortOrder        Int      @default(0)
  post             Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
}

model Comment {
  id             String          @id @default(cuid())
  postId         String
  authorId       String
  body           String
  status         CommentStatus   @default(PUBLISHED)
  communityScore Float           @default(0)
  post           Post            @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)
  author         User            @relation(fields: [authorId], references: [id])
  commentLikes   CommentLike[]
  bestForPosts   Post[]          @relation("PostBestComment")
  reports        CommentReport[]
  scoreEvents    CommunityScoreEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([postId, status, createdAt])
  @@index([postId, status, id])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId, createdAt])
  @@index([userId, createdAt])
}

model ModerationAction {
  id         String   @id @default(cuid())
  actorId    String
  targetType String
  targetId   String
  actionType String
  reason     String?
  actor      User     @relation("ModerationActor", fields: [actorId], references: [id])
  createdAt  DateTime @default(now())

  @@index([targetType, targetId, createdAt])
}

model UserRestriction {
  id                String     @id @default(cuid())
  userId            String
  status            UserStatus
  reason            String
  createdById       String
  reviewedByAdminId String?
  startsAt          DateTime   @default(now())
  endsAt            DateTime?
  createdAt         DateTime   @default(now())
  user              User       @relation("RestrictedUser", fields: [userId], references: [id])
  createdBy         User       @relation("RestrictionCreatedBy", fields: [createdById], references: [id])
  reviewedByAdmin   User?      @relation("RestrictionReviewedBy", fields: [reviewedByAdminId], references: [id])

  @@index([userId, status])
}

model SearchAlert {
  id            String   @id @default(cuid())
  userId        String
  query         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, query])
  @@index([userId, createdAt])
}

model KakaoMessageDelivery {
  id               String                     @id @default(cuid())
  deliveryType     KakaoMessageDeliveryType
  recipientUserId  String
  messageText      String
  targetUrl        String?
  status           KakaoMessageDeliveryStatus @default(PENDING)
  attemptCount     Int                        @default(0)
  lastAttemptAt    DateTime?
  sentAt           DateTime?
  errorMessage     String?
  relatedPostId    String?
  searchQuery      String?
  retriedByAdminId String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  recipientUser    User                       @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([status, createdAt(sort: Desc)])
  @@index([recipientUserId, createdAt(sort: Desc)])
  @@index([deliveryType, createdAt(sort: Desc)])
}

model CommunityScoreEvent {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  postId     String?
  commentId  String?
  actorId    String?
  baseDelta  Float
  weight     Float
  finalDelta Float
  reason     String
  metadata   Json?
  createdAt  DateTime @default(now())
  post       Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId, createdAt])
  @@index([postId, createdAt])
  @@index([commentId, createdAt])
}

model Notification {
  id              String           @id @default(cuid())
  recipientId     String
  type            NotificationType
  isRead          Boolean          @default(false)
  relatedPostId   String?
  relatedCommentId String?
  actorId         String?
  createdAt       DateTime         @default(now())
  recipient       User             @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@index([recipientId, createdAt(sort: Desc)])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NeighbourWarmthLog {
  id             String   @id @default(cuid())
  userId         String
  reason         String
  baseDelta      Float
  actualDelta    Float
  previousWarmth Float
  newWarmth      Float
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model OperatorProfile {
  id          String   @id @default(cuid())
  displayName String
  slug        String   @unique
  avatarUrl   String?
  bio         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}
