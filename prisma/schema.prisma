generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  COORDINATOR
  ADMIN
}

enum AccountType {
  REAL_USER
  PERSONA
  OPERATOR
  SYSTEM
}

enum UserStatus {
  ACTIVE
  LIMITED
  SUSPENDED
  DELETED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HELD
  DELETED
}

enum CommentStatus {
  PUBLISHED
  HELD
  DELETED
}

enum CategoryType {
  GENERAL
  QUESTION
  SALE
  GIVEAWAY
  RECRUIT
  HOUSING
  SERVICE
  EVENT
  COLUMN
  ADVERTISEMENT
  NOTICE
}

enum CategoryVisibilityMode {
  NORMAL
  ALWAYS_INCLUDED
  HIDDEN
  OPERATOR_BOARD
  OPERATOR_NOTICE
}

enum PermissionSubjectType {
  USER
  ROLE
}

enum KakaoMessageDeliveryType {
  SEARCH_ALERT
  COMMENT_NOTIFICATION
  AD_PROPOSAL_SUBMITTED
  AD_CAMPAIGN_REVIEW_REQUESTED
  AD_CAMPAIGN_APPROVED
  AD_CAMPAIGN_CHANGES_REQUESTED
}

enum NotificationType {
  POST_LIKE
  COMMENT_CREATED
  COMMENT_LIKE
  BEST_COMMENT_SELECTED
  POST_HELD
  COMMENT_HELD
  AD_PROPOSAL_SUBMITTED
  AD_CAMPAIGN_REVIEW_REQUESTED
  AD_CAMPAIGN_APPROVED
  AD_CAMPAIGN_CHANGES_REQUESTED
}

enum NotificationTargetType {
  POST
  COMMENT
  AD_PROPOSAL
  AD_CAMPAIGN
  SYSTEM
}

enum KakaoMessageDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ReportReviewStatus {
  PENDING
  VALID
  FALSE_REPORT
}

enum StaffRole {
  MODERATOR
  COORDINATOR
  AD_MANAGER
  PARTNER_MANAGER
  ADMIN
}

enum LocationChangeType {
  CITY_CHANGED
  COUNTRY_CHANGED_CITY_RESET
  ADMIN_OVERRIDE
}

enum AdPlacementType {
  TOP_FIXED
  FEED_INLINE
}

enum AdSize {
  S
  M
  L
}

enum AdLayout {
  TEXT
  THUMBNAIL
  IMAGE
  FEATURED
}

enum AdCampaignStatus {
  DRAFT
  REVIEW
  APPROVED
  REQUEST_CHANGES
  ACTIVE
  PAUSED
  ENDED
  CANCELLED
}

enum AdBillingUnit {
  DAY
  WEEK
  MONTH
  IMPRESSION_1000
}

enum AdBillingStatus {
  DRAFT
  ESTIMATED
  INVOICED
  PAID
  WAIVED
  CANCELLED
}

enum AdvertiserMemberRole {
  OWNER
  MEMBER
}

enum AdProposalStatus {
  SUBMITTED
  IN_NEGOTIATION
  NEGOTIATED
  REJECTED
}

enum AdContentStatus {
  DRAFT
  REVIEW
  APPROVED
  REJECTED
}

enum PartnerIncentiveStatus {
  DRAFT
  CONFIRMED
  PAID
}

model User {
  id                   String             @id @default(cuid())
  kakaoId              String             @unique
  displayName          String
  profileImageUrl      String?
  shortBio             String?
  neighbourWarmth      Float              @default(36.5)
  kakaoAccessToken     String?
  kakaoRefreshToken    String?
  kakaoAccessTokenExpiresAt DateTime?
  openChatUrl          String?
  cityId               String?
  countryId            String?
  accountType          AccountType        @default(REAL_USER)
  isManagedAccount     Boolean            @default(false)
  isActive             Boolean            @default(true)
  status               UserStatus         @default(ACTIVE)
  personaNotes         String?
  toneNotes            String?
  activityNotes        String?
  city                 City?              @relation(fields: [cityId], references: [id])
  country              Country?           @relation(fields: [countryId], references: [id])
  posts                Post[]
  createdPosts         Post[]             @relation("PostCreatedBy")
  comments             Comment[]
  createdComments      Comment[]          @relation("CommentCreatedBy")
  sessions             Session[]
  moderationLogs       ModerationAction[] @relation("ModerationActor")
  restrictions         UserRestriction[]  @relation("RestrictedUser")
  createdRestrictions  UserRestriction[]  @relation("RestrictionCreatedBy")
  reviewedRestrictions UserRestriction[]  @relation("RestrictionReviewedBy")
  notifyOnKakaoForSearchAlert Boolean            @default(true)
  notifyOnKakaoForComment     Boolean            @default(true)
  searchAlerts         SearchAlert[]
  postReports          PostReport[]
  commentReports       CommentReport[]
  savedPosts           SavedPost[]
  postViews            PostView[]
  postLikes            PostLike[]
  commentLikes         CommentLike[]
  postPermissions      PostPermission[]
  kakaoMessageDeliveries KakaoMessageDelivery[]
  notifications        Notification[]
  reviewedPostReports  PostReport[]         @relation("PostReportReviewer")
  reviewedCommentReports CommentReport[]    @relation("CommentReportReviewer")
  warmthLogs           NeighbourWarmthLog[]
  locationChangeLogs   LocationChangeLog[] @relation("LocationChangeUser")
  actedLocationChanges LocationChangeLog[] @relation("LocationChangeActor")
  staffAssignments     StaffAssignment[]
  advertiserMemberships AdvertiserMember[]
  submittedAdProposals AdProposal[] @relation("AdProposalSubmittedBy")
  negotiatedAdProposals AdProposal[] @relation("AdProposalNegotiatedBy")
  adContentsCreated AdContent[] @relation("AdContentCreatedBy")
  adContentsReviewed AdContent[] @relation("AdContentReviewedBy")
  reviewedAdCampaigns AdCampaign[] @relation("AdCampaignReviewedBy")
  priceConfirmedAdCampaigns AdCampaign[] @relation("AdCampaignPriceConfirmedBy")
  sourcedAdCampaigns AdCampaign[] @relation("AdCampaignSourcedBy")
  adAuditLogs AdAuditLog[] @relation("AdAuditActor")
  partnerIncentives PartnerIncentive[] @relation("PartnerIncentivePartner")
  confirmedIncentives PartnerIncentive[] @relation("PartnerIncentiveConfirmedBy")
  paidIncentives PartnerIncentive[] @relation("PartnerIncentivePaidBy")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Country {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  users       User[]
  cities      City[]
  posts       Post[]
  permissions PostPermission[]
  adCampaigns AdCampaign[]    @relation("AdCampaignTargetCountry")
  adGeoPricings AdGeoPricing[]
  advertisers Advertiser[]
  staffAssignments StaffAssignment[]
}

model City {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  countryId String?
  country   Country? @relation(fields: [countryId], references: [id])
  users     User[]
  posts     Post[]
  permissions PostPermission[]
  adCampaigns AdCampaign[]    @relation("AdCampaignTargetCity")
  adGeoPricings AdGeoPricing[]
  advertisers Advertiser[]
  staffAssignments StaffAssignment[]
}

model Category {
  id             String                 @id @default(cuid())
  name           String
  slug           String                 @unique
  type           CategoryType           @default(GENERAL)
  visibilityMode CategoryVisibilityMode @default(NORMAL)
  color          String?
  requireCommentBeforeContactDefault Boolean @default(false)
  contactSectionDefaultExpanded      Boolean @default(false)
  quickCommentTemplates Json?
  isActive       Boolean                @default(true)
  sortOrder      Int                    @default(0)
  posts          Post[]
  permissions    PostPermission[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model PostTagOption {
  id           String       @id @default(cuid())
  categoryType CategoryType
  label        String
  slug         String
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  posts        PostTag[]

  @@unique([categoryType, label])
  @@unique([categoryType, slug])
  @@index([categoryType, isActive, sortOrder])
}

model PostPermission {
  id          String                @id @default(cuid())
  subjectType PermissionSubjectType
  userId      String?
  role        UserRole?
  countryId   String?
  cityId      String?
  categoryId  String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  user        User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  country     Country?              @relation(fields: [countryId], references: [id], onDelete: Cascade)
  city        City?                 @relation(fields: [cityId], references: [id], onDelete: Cascade)
  category    Category?             @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([subjectType, userId])
  @@index([subjectType, role])
  @@index([countryId, cityId, categoryId])
}

model Post {
  id              String       @id @default(cuid())
  authorId        String
  createdByUserId String?
  cityId          String?
  countryId       String?
  categoryId      String
  title           String?
  body            String
  price           Decimal?     @db.Decimal(10, 2)
  status          PostStatus   @default(PUBLISHED)
  communityScore  Float        @default(0)
  viewCount       Int          @default(0)
  requireCommentBeforeContact Boolean @default(false)
  isPinned        Boolean      @default(false)
  pinnedAt        DateTime?
  heldReason      String?
  deletedReason   String?
  author          User         @relation(fields: [authorId], references: [id])
  createdByUser   User?        @relation("PostCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  city            City?        @relation(fields: [cityId], references: [id])
  country         Country?     @relation(fields: [countryId], references: [id])
  category        Category     @relation(fields: [categoryId], references: [id])
  contactUrl      String?
  images          PostImage[]
  tags            PostTag[]
  comments        Comment[]    @relation("PostComments")
  postLikes       PostLike[]
  bestCommentId   String?
  bestComment     Comment?     @relation("PostBestComment", fields: [bestCommentId], references: [id], onDelete: SetNull)
  reports         PostReport[]
  savedBy         SavedPost[]
  views           PostView[]
  scoreEvents     CommunityScoreEvent[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  publishedAt     DateTime?    @default(now())
  heldAt          DateTime?
  deletedAt       DateTime?

  @@index([cityId, categoryId, status, createdAt])
  @@index([authorId, createdAt])
  @@index([status, createdAt])
  @@index([status, isPinned(sort: Desc), pinnedAt(sort: Desc), createdAt(sort: Desc), id])
  @@index([status, countryId, createdAt, id])
  @@index([status, cityId, createdAt, id])
  @@index([status, categoryId, createdAt, id])
  @@index([authorId, status, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([bestCommentId])
  @@index([status, communityScore(sort: Desc), createdAt(sort: Desc)])
  @@index([status, viewCount(sort: Desc), createdAt(sort: Desc)])
}

model PostTag {
  postId          String
  postTagOptionId String
  createdAt       DateTime      @default(now())
  post            Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  postTagOption   PostTagOption @relation(fields: [postTagOptionId], references: [id], onDelete: Cascade)

  @@id([postId, postTagOptionId])
  @@index([postTagOptionId, createdAt])
  @@index([postId, createdAt])
  @@index([postTagOptionId, postId])
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@index([userId, createdAt, id])
  @@index([postId, createdAt])
}

model PostView {
  id          String   @id @default(cuid())
  postId      String
  userId      String?
  fingerprint String?
  windowKey   String
  viewedAt    DateTime @default(now())
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([postId, userId, windowKey])
  @@unique([postId, fingerprint, windowKey])
  @@index([postId, viewedAt(sort: Desc)])
  @@index([postId, userId, viewedAt(sort: Desc)])
  @@index([postId, fingerprint, viewedAt(sort: Desc)])
  @@index([viewedAt, postId])
}

model ReportOption {
  id             String          @id @default(cuid())
  label          String          @unique
  isActive       Boolean         @default(true)
  sortOrder      Int             @default(0)
  reports        PostReport[]
  commentReports CommentReport[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PostReport {
  id               String       @id @default(cuid())
  postId           String
  reporterId       String
  optionId         String
  additionalReason String?
  reviewStatus     ReportReviewStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewedById     String?
  post             Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter         User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy       User?        @relation("PostReportReviewer", fields: [reviewedById], references: [id])
  option           ReportOption @relation(fields: [optionId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([postId, reporterId])
  @@index([postId, createdAt])
  @@index([reporterId, createdAt])
  @@index([reviewStatus, createdAt])
}

model CommentReport {
  id               String       @id @default(cuid())
  commentId        String
  reporterId       String
  optionId         String
  additionalReason String?
  reviewStatus     ReportReviewStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewedById     String?
  comment          Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter         User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy       User?        @relation("CommentReportReviewer", fields: [reviewedById], references: [id])
  option           ReportOption @relation(fields: [optionId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([commentId, reporterId])
  @@index([commentId, createdAt])
  @@index([reporterId, createdAt])
  @@index([reviewStatus, createdAt])
}

model PostImage {
  id               String   @id @default(cuid())
  postId           String
  url              String
  provider         String
  providerPublicId String?
  width            Int?
  height           Int?
  sortOrder        Int      @default(0)
  post             Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
}

model Comment {
  id             String          @id @default(cuid())
  postId         String
  authorId       String
  createdByUserId String?
  body           String
  status         CommentStatus   @default(PUBLISHED)
  communityScore Float           @default(0)
  post           Post            @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)
  author         User            @relation(fields: [authorId], references: [id])
  createdByUser  User?           @relation("CommentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  commentLikes   CommentLike[]
  bestForPosts   Post[]          @relation("PostBestComment")
  reports        CommentReport[]
  scoreEvents    CommunityScoreEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([postId, status, createdAt])
  @@index([postId, status, id])
  @@index([createdByUserId, createdAt])
  @@index([createdAt, postId, status])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt, postId])
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId, createdAt])
  @@index([userId, createdAt])
}

model ModerationAction {
  id         String   @id @default(cuid())
  actorId    String
  targetType String
  targetId   String
  actionType String
  reason     String?
  actor      User     @relation("ModerationActor", fields: [actorId], references: [id])
  createdAt  DateTime @default(now())

  @@index([targetType, targetId, createdAt])
}

model UserRestriction {
  id                String     @id @default(cuid())
  userId            String
  status            UserStatus
  reason            String
  createdById       String
  reviewedByAdminId String?
  startsAt          DateTime   @default(now())
  endsAt            DateTime?
  createdAt         DateTime   @default(now())
  user              User       @relation("RestrictedUser", fields: [userId], references: [id])
  createdBy         User       @relation("RestrictionCreatedBy", fields: [createdById], references: [id])
  reviewedByAdmin   User?      @relation("RestrictionReviewedBy", fields: [reviewedByAdminId], references: [id])

  @@index([userId, status])
}

model SearchAlert {
  id            String   @id @default(cuid())
  userId        String
  query         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, query])
  @@index([userId, createdAt])
}

model KakaoMessageDelivery {
  id               String                     @id @default(cuid())
  deliveryType     KakaoMessageDeliveryType
  recipientUserId  String
  dedupeKey        String?                    @unique
  messageText      String
  targetUrl        String?
  status           KakaoMessageDeliveryStatus @default(PENDING)
  attemptCount     Int                        @default(0)
  lastAttemptAt    DateTime?
  sentAt           DateTime?
  errorMessage     String?
  relatedPostId    String?
  searchQuery      String?
  retriedByAdminId String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  recipientUser    User                       @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([status, createdAt(sort: Desc)])
  @@index([recipientUserId, createdAt(sort: Desc)])
  @@index([deliveryType, createdAt(sort: Desc)])
}

model CommunityScoreEvent {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  postId     String?
  commentId  String?
  actorId    String?
  baseDelta  Float
  weight     Float
  finalDelta Float
  reason     String
  metadata   Json?
  createdAt  DateTime @default(now())
  post       Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId, createdAt])
  @@index([postId, createdAt])
  @@index([commentId, createdAt])
}

model Notification {
  id               String                 @id @default(cuid())
  recipientId      String
  type             NotificationType
  isRead           Boolean                @default(false)
  relatedPostId    String?
  relatedCommentId String?
  targetType       NotificationTargetType @default(SYSTEM)
  targetId         String?
  targetUrl        String?
  metadata         Json?
  actorId          String?
  createdAt        DateTime               @default(now())
  recipient        User                   @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@index([recipientId, createdAt(sort: Desc)])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NeighbourWarmthLog {
  id             String   @id @default(cuid())
  userId         String
  reason         String
  baseDelta      Float
  actualDelta    Float
  previousWarmth Float
  newWarmth      Float
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model LocationChangeLog {
  id              String             @id @default(cuid())
  userId          String
  actorId         String
  changeType      LocationChangeType
  beforeCountryId String?
  afterCountryId  String?
  beforeCityId    String?
  afterCityId     String?
  user            User               @relation("LocationChangeUser", fields: [userId], references: [id], onDelete: Cascade)
  actor           User               @relation("LocationChangeActor", fields: [actorId], references: [id], onDelete: Cascade)
  createdAt       DateTime           @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
}

model AdProduct {
  id            String          @id @default(cuid())
  code          String          @unique
  name          String
  placementType AdPlacementType
  size          AdSize          @default(M)
  layout        AdLayout        @default(THUMBNAIL)
  currency      String          @default("NZD")
  billingUnit   AdBillingUnit   @default(DAY)
  basePrice     Decimal         @db.Decimal(10, 2) @default(0)
  isActive      Boolean         @default(true)
  sortOrder     Int             @default(0)
  description   String?
  campaigns     AdCampaign[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model AdCampaign {
  id              String           @id @default(cuid())
  advertiserId    String?
  adContentId     String?
  adProductId     String
  status          AdCampaignStatus @default(DRAFT)
  priority        Int              @default(0)
  startAt         DateTime?
  endAt           DateTime?
  maxImpressions  Int?
  targetCountryId String?
  targetCityId    String?
  estimatedAmount Decimal?          @db.Decimal(10, 2)
  proposedAmount  Decimal?          @db.Decimal(10, 2)
  finalAmount     Decimal?          @db.Decimal(10, 2)
  billingStatus   AdBillingStatus   @default(DRAFT)
  pricingSnapshot Json?
  pricingConfirmationSnapshot Json?
  priceAdjustmentReason String?
  priceConfirmedByUserId String?
  priceConfirmedAt DateTime?
  landingUrl      String?
  notes           String?
  reviewNotes     String?
  reviewedByUserId String?
  reviewedAt      DateTime?
  sourcedByUserId String?
  adContent       AdContent?       @relation(fields: [adContentId], references: [id], onDelete: Cascade)
  advertiser      Advertiser?      @relation(fields: [advertiserId], references: [id], onDelete: SetNull)
  adProduct       AdProduct        @relation(fields: [adProductId], references: [id])
  targetCountry   Country?         @relation("AdCampaignTargetCountry", fields: [targetCountryId], references: [id])
  targetCity      City?            @relation("AdCampaignTargetCity", fields: [targetCityId], references: [id])
  reviewedByUser  User?            @relation("AdCampaignReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  priceConfirmedByUser User?       @relation("AdCampaignPriceConfirmedBy", fields: [priceConfirmedByUserId], references: [id], onDelete: SetNull)
  sourcedByUser   User?            @relation("AdCampaignSourcedBy", fields: [sourcedByUserId], references: [id], onDelete: SetNull)
  impressions     AdImpression[]
  clicks          AdClick[]
  dailyStats      AdDailyStat[]
  auditLogs       AdAuditLog[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, startAt, endAt])
  @@index([status, startAt, endAt, targetCountryId, targetCityId])
  @@index([adProductId, status])
  @@index([advertiserId, status])
  @@index([adContentId, status])
  @@index([targetCountryId, status])
  @@index([targetCityId, status])
  @@index([sourcedByUserId, status])
}

model AdPlacementRule {
  id             String          @id @default(cuid())
  placementType  AdPlacementType @unique
  insertAfter    Int             @default(5)
  repeatInterval Int             @default(10)
  maxPerPage     Int             @default(2)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model AdImpression {
  id                String          @id @default(cuid())
  campaignId        String
  adContentId       String
  placementType     AdPlacementType
  pageKey           String
  positionIndex     Int
  viewerUserId      String?
  viewerFingerprint String?
  viewedAt          DateTime        @default(now())
  campaign          AdCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  @@index([campaignId, viewedAt])
  @@index([adContentId, viewedAt])
  @@index([viewedAt])
}

model AdClick {
  id                String     @id @default(cuid())
  campaignId        String
  adContentId       String
  impressionId      String?
  viewerUserId      String?
  viewerFingerprint String?
  clickedAt         DateTime   @default(now())
  campaign          AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  @@index([campaignId, clickedAt])
  @@index([adContentId, clickedAt])
  @@index([clickedAt])
}

model AdDailyStat {
  id          String     @id @default(cuid())
  campaignId  String
  date        DateTime   @db.Date
  impressions Int        @default(0)
  clicks      Int        @default(0)
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId, date(sort: Desc)])
  @@index([date(sort: Desc)])
}

model AdGeoPricing {
  id            String    @id @default(cuid())
  countryId     String?
  cityId        String?
  multiplier    Decimal   @db.Decimal(8, 4)
  isActive      Boolean   @default(true)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  country       Country?  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  city          City?     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([cityId, isActive, effectiveFrom, effectiveTo])
  @@index([countryId, isActive, effectiveFrom, effectiveTo])
}


model StaffAssignment {
  id        String    @id @default(cuid())
  userId    String
  role      StaffRole
  countryId String?
  cityId    String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  country   Country?  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  city      City?     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([role, isActive])
  @@index([countryId, cityId])
}

model Advertiser {
  id             String             @id @default(cuid())
  name           String
  slug           String             @unique
  countryId      String?
  cityId         String?
  contactEmail   String?
  contactPhone   String?
  websiteUrl     String?
  isActive       Boolean            @default(true)
  notes          String?
  country        Country?           @relation(fields: [countryId], references: [id], onDelete: SetNull)
  city           City?              @relation(fields: [cityId], references: [id], onDelete: SetNull)
  members        AdvertiserMember[]
  proposals      AdProposal[]
  adContents     AdContent[]
  adCampaigns    AdCampaign[]
  auditLogs      AdAuditLog[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([countryId, cityId])
}

model AdvertiserMember {
  id            String               @id @default(cuid())
  advertiserId  String
  userId        String
  role          AdvertiserMemberRole @default(MEMBER)
  isActive      Boolean              @default(true)
  advertiser    Advertiser           @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([advertiserId, userId])
  @@index([userId, isActive])
  @@index([advertiserId, role, isActive])
}

model AdProposal {
  id                    String           @id @default(cuid())
  advertiserId          String
  submittedByUserId     String?
  negotiatedByUserId    String?
  status                AdProposalStatus @default(SUBMITTED)
  title                 String
  body                  String
  requestedStartAt      DateTime?
  requestedEndAt        DateTime?
  requestedBudget       Decimal?         @db.Decimal(10, 2)
  requestedLandingUrl   String?
  negotiationNotes      String?
  rejectedReason        String?
  advertisedProductCode String?
  advertiser            Advertiser       @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  submittedByUser       User?            @relation("AdProposalSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  negotiatedByUser      User?            @relation("AdProposalNegotiatedBy", fields: [negotiatedByUserId], references: [id], onDelete: SetNull)
  adContent             AdContent?
  auditLogs             AdAuditLog[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([advertiserId, status, createdAt])
  @@index([status, updatedAt])
}

model AdContent {
  id               String          @id @default(cuid())
  advertiserId     String
  proposalId       String?         @unique
  createdByUserId  String?
  reviewedByUserId String?
  status           AdContentStatus @default(DRAFT)
  title            String?
  body             String
  thumbnailUrl     String?
  landingUrl       String?
  displayName      String?
  categoryName     String?
  cityName         String?
  reviewNotes      String?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  advertiser       Advertiser      @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  proposal         AdProposal?     @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  createdByUser    User?           @relation("AdContentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reviewedByUser   User?           @relation("AdContentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  campaigns        AdCampaign[]
  auditLogs        AdAuditLog[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([advertiserId, status, createdAt])
  @@index([status, updatedAt])
}

model AdAuditLog {
  id            String   @id @default(cuid())
  actorId       String?
  advertiserId  String?
  proposalId    String?
  adContentId   String?
  campaignId    String?
  actionType    String
  message       String?
  metadata      Json?
  actor         User?    @relation("AdAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  advertiser    Advertiser? @relation(fields: [advertiserId], references: [id], onDelete: SetNull)
  proposal      AdProposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  adContent     AdContent?  @relation(fields: [adContentId], references: [id], onDelete: SetNull)
  campaign      AdCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([proposalId, createdAt])
  @@index([adContentId, createdAt])
  @@index([advertiserId, createdAt])
}

model PartnerIncentive {
  id                String                 @id @default(cuid())
  partnerUserId     String
  periodStart       DateTime
  periodEnd         DateTime
  totalSalesAmount  Decimal                @db.Decimal(10, 2)
  incentiveRate     Decimal                @db.Decimal(8, 4)
  incentiveAmount   Decimal                @db.Decimal(10, 2)
  currency          String                 @default("NZD")
  status            PartnerIncentiveStatus @default(DRAFT)
  notes             String?
  paidAt            DateTime?
  confirmedByUserId String?
  paidByUserId      String?
  campaignSnapshots Json?
  partnerUser       User                   @relation("PartnerIncentivePartner", fields: [partnerUserId], references: [id])
  confirmedByUser   User?                  @relation("PartnerIncentiveConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  paidByUser        User?                  @relation("PartnerIncentivePaidBy", fields: [paidByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([partnerUserId, status])
  @@index([partnerUserId, periodStart, periodEnd])
  @@index([status, createdAt(sort: Desc)])
}
